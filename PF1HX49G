<!DOCTYPE html>
<html>
<head>
    <title>My Portfolio</title>

    <style>
        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            font-family: Arial;
        }

        /* Navbar */
        nav {
            background: black;
            padding: 15px;
            position: fixed;
            width: 100%;
            top: 0;
        }

        nav a {
            color: white;
            margin: 10px;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:hover {
            color: yellow;
        }

        section {
            padding: 80px 20px;
            min-height: 100vh;
        }

        #home { background: lightblue; text-align: center; }
        #about { background: lightgreen; }
        #contact { background: lightcoral; }

        button {
            padding: 10px 20px;
            background: black;
            color: white;
            border: none;
            cursor: pointer;
        }

        button:hover {
            background: gray;
        }

        /* Intro Box */
        #introBox {
            display: none;
            margin-top: 20px;
            padding: 15px;
            background: white;
            border-radius: 10px;
        }

        /* Projects Section */
        #projects {
            background: #f0e68c;
        }

        .projects-container {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            justify-content: center;
        }

        .project {
            background: white;
            padding: 15px;
            width: 280px;
            border-radius: 10px;
            text-align: center;
        }

        .project img {
            width: 100%;
            border-radius: 10px;
        }
    </style>
</head>

<body>

<!-- Navbar -->
<nav>
    <a href="#home">Home</a>
    <a href="#about">About</a>
    <a href="#projects">Projects</a>
    <a href="#contact">Contact</a>
</nav>

<!-- Home -->
<section id="home">
    <h1>Hello, I'm Anuja Chavan 👋</h1>
    <p>Welcome to my portfolio</p>

    <button onclick="showIntro()">Know More</button>

    <div id="introBox">
        <p>I am passionate about web development and love creating simple websites.</p>
    </div>
</section>

<!-- About -->
<section id="about">
    <h1>About Me</h1>
    <p>
        Hello! I am Anuja, a first-year Mechanical Engineering student with a strong interest in technology and innovation. 
        Along with my core engineering studies, I am actively learning web development using HTML, CSS, and JavaScript.
    </p>

    <p>
        I enjoy creating simple and functional websites, and I am constantly improving my skills by building small projects. 
        I have also worked on practical projects like an Automatic Watering System using Arduino, which helped me understand real-world problem solving.
    </p>

    <p>
        I am a curious learner who likes exploring new ideas, improving technical skills, and working on creative solutions. 
        My goal is to grow as an engineer and develop useful projects that can make everyday life easier.
    </p>

    
</section>

<!-- Projects -->
<section id="projects">
    <h1 style="text-align:center;">My Projects</h1>

    <div class="projects-container">

        <div class="project">
            <h3>Fusion 360 Design 1</h3>
            <img src="photo1.png.png">
            
        </div>

        <div class="project">
            <h3>Fusion 360 Design 2</h3>
            <img src="photo2.png.png">
            
        </div>

        <div class="project">
            <h3>Fusion 360 Design 3</h3>
            <img src="photo3.png.png">
            
        </div>

    </div>
</section>

<!-- Contact -->
<section id="contact">
    <h1>Contact Me</h1>
    <p>Email: anuchavan050@email.com</p>
    <p>Phone: 9022262675</p>
</section>

<!-- JavaScript -->
<script>
    function showIntro() {
        let box = document.getElementById("introBox");

        if (box.style.display === "none" || box.style.display === "") {
            box.style.display = "block";
        } else {
            box.style.display = "none";
        }
    }
</script>

</body>
</html>